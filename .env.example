# Local-dev deploy config for scripts/deploy-dev.sh — copy to .env and edit.
# .env is gitignored (machine-specific paths); this template is committed.
# DEV-ONLY: SeedSigner OS bakes its own image and does not use this.
#
# This deploy points ONLY at the app: it pushes $SS_APP_DIR/src/lang-packs (the
# app's already-bundled packs) to the device. It does not know the pack repo and
# does not build packs. Populate the app's src/lang-packs from the live pack-repo
# checkout: `build_packs.sh --out-dir $SS_APP_DIR/src/lang-packs`.

# Target device (SSH host). Required.
SS_DEVICE=pi@seedsigner.local

# The SeedSigner app checkout root on THIS machine. Required.
# Its src/seedsigner/ (code) and src/lang-packs/ (packs) are what get deployed.
SS_APP_DIR=/home/kdmukai/dev/seedsigner

# The built .so to deploy. Optional — defaults to the newest
# src/seedsigner_lvgl_screens*.so in this repo (produced by ./run_build.sh).
#SS_SO_PATH=/home/kdmukai/dev/seedsigner-raspi-lvgl/src/seedsigner_lvgl_screens.cpython-310-arm-linux-gnueabihf.so

# Device-side paths (standard SeedSigner Pi layout). Optional — override only for
# a non-standard device.
#SS_DEVICE_APP_DIR=/home/pi/seedsigner/src
#SS_DEVICE_SO_DIR=/home/pi/seedsigner-raspi-lvgl/src
